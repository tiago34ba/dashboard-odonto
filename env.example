# Configurações de Ambiente - Dashboard Odonto
# Copie este arquivo para .env.local e configure as variáveis

# API Configuration
REACT_APP_API_BASE_URL=https://seu-dominio.com/api
REACT_APP_API_URL=https://seu-dominio.com/api
REACT_APP_API_TIMEOUT=10000

# Security Configuration
REACT_APP_ENCRYPTION_KEY=
REACT_APP_ENABLE_CLIENT_ENCRYPTION=false
REACT_APP_ENABLE_HTTPS=true

# Development Configuration
REACT_APP_NODE_ENV=production
REACT_APP_ENABLE_DEBUG=false

# Release Configuration
REACT_APP_RELEASE=dashboard-odonto@1.0.0
REACT_APP_ENVIRONMENT=production

# Error Monitoring (Sentry)
REACT_APP_ENABLE_SENTRY=true
REACT_APP_SENTRY_DSN=
REACT_APP_SENTRY_ENVIRONMENT=production
REACT_APP_SENTRY_TRACES_SAMPLE_RATE=0.1

# CORS Configuration
REACT_APP_ALLOWED_ORIGINS=https://seu-dominio.com,https://www.seu-dominio.com

# PIX e Mercado Pago
REACT_APP_PIX_KEY=
REACT_APP_PIX_AGENCIA=
REACT_APP_PIX_CONTA=
REACT_APP_PIX_BANCO_NOME=
REACT_APP_PIX_BANCO_CODIGO=
REACT_APP_MERCADOPAGO_API_URL=https://api.mercadopago.com/v1
REACT_APP_MERCADOPAGO_TOKEN=
REACT_APP_PIX_MOCK_API_URL=http://localhost:3001/api/pix
REACT_APP_IS_PRODUCTION=false
